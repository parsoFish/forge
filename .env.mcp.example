# MCP Server Environment Variables
#
# Copy this file to .env.mcp and fill in your values.
# .env.mcp is gitignored — never commit real tokens.
#
# Usage: source .env.mcp before running Claude Code, or
#        the setup script loads it automatically.

# ── GitHub MCP ────────────────────────────────────────────────────────
# Required for: PR management, issue triage, code search, repo operations
# Create at: https://github.com/settings/tokens
# Scopes needed: repo, read:org
GITHUB_PERSONAL_ACCESS_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Docker MCP ────────────────────────────────────────────────────────
# Optional: Docker socket path (defaults to /var/run/docker.sock)
# DOCKER_HOST=unix:///var/run/docker.sock

# ── Terraform MCP ────────────────────────────────────────────────────
# Optional: Terraform Cloud API token for remote state/workspace ops
# Create at: https://app.terraform.io/app/settings/tokens
# TF_TOKEN=xxxxxxxxxx.atlasv1.xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Plex MCP (optional — install separately) ─────────────────────────
# Only needed if you install the Plex MCP server for simplarr
# PLEX_URL=http://localhost:32400
# PLEX_TOKEN=xxxxxxxxxxxxxxxxxxxx
